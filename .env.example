EWS_CONFIG_PATH=/app/config/config.yaml
EWS_HOST=0.0.0.0
EWS_PORT=8091
EWS_BEARER_TOKEN=

# Provider and integration endpoints
SEARXNG_BASE_URL=http://searxng:8080
LITELLM_SEARCH_BASE_URL=http://litellm:4000
LITELLM_API_KEY=
LITELLM_ENABLED_PROVIDERS=brave-search,serper,exa,tavily
FLARESOLVERR_URL=
VANE_ENABLED=false
VANE_URL=http://vane:3000
VANE_DEFAULT_MODE=balanced

# Provider-specific keys are not required when LiteLLM uses one gateway key.

# Optional vane provider settings
VANE_CHAT_PROVIDER_ID=
VANE_EMBED_PROVIDER_ID=
VANE_CHAT_MODEL_KEY=auto-main
VANE_EMBED_MODEL_KEY=Xenova/nomic-embed-text-v1
